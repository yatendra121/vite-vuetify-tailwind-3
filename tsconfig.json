{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noImplicitThis": true,
    "lib": ["esnext", "dom"],
    "allowJs": true,
    "types": ["vitest/globals"],
    "paths": {
      "@/*": ["src/*"],
      "vue": ["./node_modules/vue"],
      "vue/dist/*": ["./node_modules/vue/dist/*"],
      "@vue/reactivity": ["./node_modules/@vue/reactivity"],
      "@vue/runtime-core": ["./node_modules/@vue/runtime-core"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["src/**/*.test_spec.ts", "tests/**/*.ts", "src/store/core/**"]
}

